<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Streaker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#0F0F12</item>
        <item name="android:navigationBarColor">#0F0F12</item>
    </style>

    <style name="Theme.Streaker.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0F12</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenIconBackgroundColor">#0F0F12</item>
        <item name="postSplashScreenTheme">@style/Theme.Streaker</item>
    </style>

</resources>